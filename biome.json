{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/android",
      "!**/ios",
      "!**/dist",
      "!**/.expo",
      "!**/.sisyphus"
    ]
  }
}
